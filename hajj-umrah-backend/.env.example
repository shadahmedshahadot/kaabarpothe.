NODE_ENV=development
PORT=9000

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
BCRYPT_SALT_ROUNDS=10

JWT_ACCESS_TOKEN_SECRET="your_access_token_secret_here"
JWT_REFRESH_TOKEN_SECRET="your_refresh_token_secret_here"

JWT_ACCESS_TOKEN_EXPIRES_IN="7d"
JWT_REFRESH_TOKEN_EXPIRES_IN="90d"

STRIPE_SECRET_KEY="your_stripe_secret_key_here"
PUBLISH_KEY="your_stripe_publish_key_here"
